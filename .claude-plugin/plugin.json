{
  "name": "aegis",
  "version": "1.0.0",
  "description": "Harness security for Claude Code — 4 runtime hooks that block attacks your prompt can't see",
  "homepage": "https://github.com/ftuga/aegis",
  "license": "AGPL-3.0",
  "keywords": ["security", "claude-code", "agent", "hooks", "prompt-injection"],
  "hooks": {
    "PostToolUse": [
      {"matcher": "WebFetch|WebSearch|Read", "command": "hooks/injection-detector.sh"}
    ],
    "PreToolUse": [
      {"matcher": "Bash", "command": "hooks/network-egress.sh"},
      {"matcher": "Write|Edit|MultiEdit|Bash", "command": "hooks/secrets-scanner.sh"}
    ]
  },
  "commands": [
    {"name": "aegis-verify", "file": "commands/aegis-verify.md"}
  ]
}
